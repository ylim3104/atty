{
  "name": "atty",
  "displayName": "아띠 atty",
  "publisher": "atty",
  "repository": {"type": "git", "url": "https://github.com/ylim3104/atty"},
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./src/atty_linters/pythonParser.js",
  "contributes": {
    "languages": [
      {
        "id": "atty",
        "aliases": ["Atty", "atty"],
        "extensions": [".atty"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "atty",
        "scopeName": "source.atty",
        "path": "./syntaxes/atty.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "atty.runCode",
        "title": "Atty: Run Translated Code",
        "icon": "$(play)"
      },
      {
        "command": "atty.exportPython",
        "title": "Atty: Export to Python (.py)",
        "icon": "$(save-as)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "atty.runCode",
          "when": "resourceExtname == .atty",
          "group": "navigation"
        },
        {
          "command": "atty.exportPython",
          "when": "resourceExtname == .atty",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "atty.exportPython",
          "when": "resourceExtname == .atty",
          "group": "2_workspace"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "tree-sitter": "^0.25.0",
    "tree-sitter-python": "^0.25.0"
  }
}
